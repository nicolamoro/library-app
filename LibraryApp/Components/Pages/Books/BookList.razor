@page "/books"
@attribute [Authorize(Roles = "admin")]
@inject BookRepository BookRepo
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Libri — Library</PageTitle>

<MudMessageBox @ref="_mbox" Title="Conferma eliminazione" CancelText="Annulla">
    <MessageContent>@_confirmMessage</MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete">Elimina</MudButton>
    </YesButton>
</MudMessageBox>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4" Style="flex:1">Catalogo Libri</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Nav.NavigateTo("/books/new"))">
        Nuovo Libro
    </MudButton>
</MudStack>

<MudTable @ref="_table" T="Book" ServerData="LoadData" Hover="true" Dense="true" Striped="true" Elevation="2" RowsPerPage="20">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField T="string" Value="_search" ValueChanged="OnSearchChanged"
                      Placeholder="Cerca..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                      Class="mt-0" DebounceInterval="300" Immediate="true" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="Book" SortLabel="title">Titolo</MudTableSortLabel></MudTh>
        <MudTh>Autori</MudTh>
        <MudTh><MudTableSortLabel T="Book" SortLabel="publisher">Editore</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="Book" SortLabel="genre">Genere</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="Book" SortLabel="year">Anno</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="Book" SortLabel="copies">Copie</MudTableSortLabel></MudTh>
        <MudTh>Azioni</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Title</MudTd>
        <MudTd>@(context.AuthorsDisplay ?? "—")</MudTd>
        <MudTd>@(context.PublisherName ?? "—")</MudTd>
        <MudTd>@(context.GenreName ?? "—")</MudTd>
        <MudTd>@(context.PublicationYear?.ToString() ?? "—")</MudTd>
        <MudTd>
            <MudChip T="string" Color="@(context.AvailableCopies > 0 ? Color.Success : Color.Error)" Size="Size.Small">
                @context.AvailableCopies / @context.TotalCopies
            </MudChip>
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => Nav.NavigateTo($"/books/{context.BookId}"))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="@(() => DeleteAsync(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[]{10, 20, 50, 100}" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<Book> _table = null!;
    private MudMessageBox _mbox = null!;
    private string _search = string.Empty;
    private string _confirmMessage = string.Empty;

    private async Task<TableData<Book>> LoadData(TableState state, CancellationToken ct)
    {
        var (items, total) = await BookRepo.GetPagedAsync(state.Page, state.PageSize, _search,
            state.SortLabel, state.SortDirection == SortDirection.Descending);
        return new TableData<Book> { Items = items, TotalItems = total };
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        await _table.ReloadServerData();
    }

    private async Task DeleteAsync(Book book)
    {
        _confirmMessage = $"Eliminare «{book.Title}»?";
        var confirmed = await _mbox.ShowAsync();
        if (confirmed != true) return;
        await BookRepo.DeleteAsync(book.BookId);
        await _table.ReloadServerData();
        Snackbar.Add($"«{book.Title}» eliminato.", Severity.Success);
    }
}
