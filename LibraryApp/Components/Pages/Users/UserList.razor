@page "/users"
@attribute [Authorize(Roles = "admin")]
@inject IUserRepository UserRepo
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Utenti — Library</PageTitle>

<MudMessageBox @ref="_mbox" Title="Conferma eliminazione" CancelText="Annulla">
    <MessageContent>@_confirmMessage</MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete">Elimina</MudButton>
    </YesButton>
</MudMessageBox>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4" Style="flex:1">Utenti</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="@(() => Nav.NavigateTo("/users/new"))">
        Nuovo Utente
    </MudButton>
</MudStack>

<MudTable @ref="_table" T="User" ServerData="LoadData" Hover="true" Dense="true" Striped="true" Elevation="2" RowsPerPage="20">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField T="string" Value="_search" ValueChanged="OnSearchChanged"
                      Placeholder="Cerca..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Class="mt-0"
                      DebounceInterval="300" Immediate="true" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="User" SortLabel="name">Nome</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="User" SortLabel="email">Email</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="User" SortLabel="role">Ruolo</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="User" SortLabel="status">Stato</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="User" SortLabel="lastlogin">Ultimo Accesso</MudTableSortLabel></MudTh>
        <MudTh>Azioni</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.FullName</MudTd>
        <MudTd>@context.Email</MudTd>
        <MudTd>
            <MudChip T="string" Color="@(context.IsAdmin ? Color.Secondary : Color.Info)" Size="Size.Small">
                @(context.IsAdmin ? "Admin" : "Cliente")
            </MudChip>
        </MudTd>
        <MudTd>
            <MudChip T="string" Color="@(context.Status == "active" ? Color.Success : Color.Warning)" Size="Size.Small">
                @(context.Status == "active" ? "Attivo" : "Sospeso")
            </MudChip>
        </MudTd>
        <MudTd>@(context.LastLogin.HasValue ? context.LastLogin.Value.ToString("dd/MM/yyyy HH:mm") : "—")</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => Nav.NavigateTo($"/users/edit/{context.UserId}"))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="@(() => DeleteAsync(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[]{10, 20, 50, 100}" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<User> _table = null!;
    private MudMessageBox _mbox = null!;
    private string _search = string.Empty;
    private string _confirmMessage = string.Empty;

    private async Task<TableData<User>> LoadData(TableState state, CancellationToken ct)
    {
        var (items, total) = await UserRepo.GetPagedAsync(state.Page, state.PageSize, _search,
            state.SortLabel, state.SortDirection == SortDirection.Descending);
        return new TableData<User> { Items = items, TotalItems = total };
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        await _table.ReloadServerData();
    }

    private async Task DeleteAsync(User user)
    {
        _confirmMessage = $"Eliminare {user.FullName}?";
        var confirmed = await _mbox.ShowAsync();
        if (confirmed != true) return;
        await UserRepo.DeleteAsync(user.UserId);
        await _table.ReloadServerData();
        Snackbar.Add($"{user.FullName} eliminato.", Severity.Success);
    }
}
