@page "/customers"
@inject CustomerRepository CustomerRepo
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Clienti — Library</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4" Style="flex:1">Clienti</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="@(() => Nav.NavigateTo("/customers/new"))">
        Nuovo Cliente
    </MudButton>
</MudStack>

@if (_customers is null)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="_customers" Hover="true" Dense="true" Striped="true" Elevation="2"
              Filter="FilterFunc">
        <ToolBarContent>
            <MudSpacer />
            <MudTextField @bind-Value="_search" Placeholder="Cerca..." Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Nome</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Telefono</MudTh>
            <MudTh>Iscritto dal</MudTh>
            <MudTh>Stato</MudTh>
            <MudTh>Azioni</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.FullName</MudTd>
            <MudTd>@(context.Email ?? "—")</MudTd>
            <MudTd>@(context.Phone ?? "—")</MudTd>
            <MudTd>@context.RegistrationDate.ToString("dd/MM/yyyy")</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.Status == "active" ? Color.Success : Color.Warning)" Size="Size.Small">
                    @(context.Status == "active" ? "Attivo" : "Sospeso")
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                               OnClick="@(() => Nav.NavigateTo($"/customers/{context.CustomerId}"))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteAsync(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private IEnumerable<Customer>? _customers;
    private string _search = string.Empty;

    protected override async Task OnInitializedAsync()
        => _customers = await CustomerRepo.GetAllAsync();

    private bool FilterFunc(Customer c) =>
        string.IsNullOrWhiteSpace(_search) ||
        c.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        (c.Email?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false);

    private async Task DeleteAsync(Customer customer)
    {
        await CustomerRepo.DeleteAsync(customer.CustomerId);
        _customers = await CustomerRepo.GetAllAsync();
        Snackbar.Add($"{customer.FullName} eliminato.", Severity.Success);
    }
}
