@page "/authors"
@attribute [Authorize(Roles = "admin")]
@inject AuthorRepository AuthorRepo
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Autori — Library</PageTitle>

<MudMessageBox @ref="_mbox" Title="Conferma eliminazione" CancelText="Annulla">
    <MessageContent>@_confirmMessage</MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete">Elimina</MudButton>
    </YesButton>
</MudMessageBox>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4" Style="flex:1">Autori</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Nav.NavigateTo("/authors/new"))">
        Nuovo Autore
    </MudButton>
</MudStack>

<MudTable @ref="_table" T="Author" ServerData="LoadData" Hover="true" Dense="true" Striped="true" Elevation="2" RowsPerPage="20">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField T="string" Value="_search" ValueChanged="OnSearchChanged"
                      Placeholder="Cerca..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                      Class="mt-0" DebounceInterval="300" Immediate="true" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="Author" SortLabel="lastname">Cognome</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="Author" SortLabel="firstname">Nome</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="Author" SortLabel="nationality">Nazionalità</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="Author" SortLabel="birthdate">Data nascita</MudTableSortLabel></MudTh>
        <MudTh>Azioni</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.LastName</MudTd>
        <MudTd>@context.FirstName</MudTd>
        <MudTd>@(context.Nationality ?? "—")</MudTd>
        <MudTd>@(context.BirthDate?.ToString("dd/MM/yyyy") ?? "—")</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => Nav.NavigateTo($"/authors/{context.AuthorId}"))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="@(() => DeleteAsync(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[]{10, 20, 50, 100}" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<Author> _table = null!;
    private MudMessageBox _mbox = null!;
    private string _search = string.Empty;
    private string _confirmMessage = string.Empty;

    private async Task<TableData<Author>> LoadData(TableState state, CancellationToken ct)
    {
        var (items, total) = await AuthorRepo.GetPagedAsync(state.Page, state.PageSize, _search,
            state.SortLabel, state.SortDirection == SortDirection.Descending);
        return new TableData<Author> { Items = items, TotalItems = total };
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        await _table.ReloadServerData();
    }

    private async Task DeleteAsync(Author author)
    {
        _confirmMessage = $"Eliminare «{author.FullName}»?";
        var confirmed = await _mbox.ShowAsync();
        if (confirmed != true) return;
        try
        {
            await AuthorRepo.DeleteAsync(author.AuthorId);
            await _table.ReloadServerData();
            Snackbar.Add($"«{author.FullName}» eliminato.", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
