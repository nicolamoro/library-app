@page "/publishers"
@attribute [Authorize(Roles = "admin")]
@inject PublisherRepository PublisherRepo
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Editori — Library</PageTitle>

<MudMessageBox @ref="_mbox" Title="Conferma eliminazione" CancelText="Annulla">
    <MessageContent>@_confirmMessage</MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete">Elimina</MudButton>
    </YesButton>
</MudMessageBox>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4" Style="flex:1">Editori</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Nav.NavigateTo("/publishers/new"))">
        Nuovo Editore
    </MudButton>
</MudStack>

<MudTable @ref="_table" T="Publisher" ServerData="LoadData" Hover="true" Dense="true" Striped="true" Elevation="2" RowsPerPage="20">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField T="string" Value="_search" ValueChanged="OnSearchChanged"
                      Placeholder="Cerca..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                      Class="mt-0" DebounceInterval="300" Immediate="true" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="Publisher" SortLabel="name">Nome</MudTableSortLabel></MudTh>
        <MudTh>Indirizzo</MudTh>
        <MudTh>Telefono</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Sito web</MudTh>
        <MudTh>Azioni</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>@(context.Address ?? "—")</MudTd>
        <MudTd>@(context.Phone ?? "—")</MudTd>
        <MudTd>@(context.Email ?? "—")</MudTd>
        <MudTd>@(context.Website ?? "—")</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => Nav.NavigateTo($"/publishers/{context.PublisherId}"))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="@(() => DeleteAsync(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[]{10, 20, 50, 100}" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<Publisher> _table = null!;
    private MudMessageBox _mbox = null!;
    private string _search = string.Empty;
    private string _confirmMessage = string.Empty;

    private async Task<TableData<Publisher>> LoadData(TableState state, CancellationToken ct)
    {
        var (items, total) = await PublisherRepo.GetPagedAsync(state.Page, state.PageSize, _search,
            state.SortLabel, state.SortDirection == SortDirection.Descending);
        return new TableData<Publisher> { Items = items, TotalItems = total };
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        await _table.ReloadServerData();
    }

    private async Task DeleteAsync(Publisher publisher)
    {
        _confirmMessage = $"Eliminare «{publisher.Name}»?";
        var confirmed = await _mbox.ShowAsync();
        if (confirmed != true) return;
        try
        {
            await PublisherRepo.DeleteAsync(publisher.PublisherId);
            await _table.ReloadServerData();
            Snackbar.Add($"«{publisher.Name}» eliminato.", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
