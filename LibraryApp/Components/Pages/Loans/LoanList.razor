@page "/loans"
@attribute [Authorize(Roles = "admin")]
@inject LoanRepository LoanRepo
@inject NavigationManager Nav

<PageTitle>Prestiti — Library</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4" Style="flex:1">Prestiti</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Nav.NavigateTo("/loans/borrow"))">
        Nuovo Prestito
    </MudButton>
</MudStack>

<MudToggleGroup T="string" Value="_filter" ValueChanged="SetFilter" Color="Color.Primary" Outlined="true" Class="mb-4">
    <MudToggleItem Value="@("all")">Tutti</MudToggleItem>
    <MudToggleItem Value="@("active")">Attivi</MudToggleItem>
    <MudToggleItem Value="@("overdue")">Scaduti</MudToggleItem>
    <MudToggleItem Value="@("returned")">Restituiti</MudToggleItem>
</MudToggleGroup>

<MudTable @ref="_table" T="LoanDetail" ServerData="LoadData" Hover="true" Dense="true" Striped="true" Elevation="2" RowsPerPage="20">
    <HeaderContent>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="id">ID</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="user">Cliente</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="book">Libro</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="loandate">Prestito</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="duedate">Scadenza</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="returndate">Restituzione</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="status">Stato</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="fine">Multa</MudTableSortLabel></MudTh>
        <MudTh>Azioni</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.LoanId</MudTd>
        <MudTd>@context.UserFullName</MudTd>
        <MudTd>@context.BookTitle</MudTd>
        <MudTd>@context.LoanDate.ToString("dd/MM/yyyy")</MudTd>
        <MudTd>@context.DueDate.ToString("dd/MM/yyyy")</MudTd>
        <MudTd>@(context.ReturnDate?.ToString("dd/MM/yyyy") ?? "—")</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">
                @context.Status
            </MudChip>
        </MudTd>
        <MudTd>
            @if (context.FineAmount.HasValue)
            {
                <MudText Color="@(context.FinePaid ? Color.Default : Color.Error)">
                    € @context.FineAmount.Value.ToString("F2")
                    @(context.FinePaid ? "✓" : "")
                </MudText>
            }
            else if (context.DaysOverdue > 0)
            {
                <MudText Color="Color.Warning">
                    ~€ @context.EstimatedFine.ToString("F2")
                </MudText>
            }
            else { <text>—</text> }
        </MudTd>
        <MudTd>
            @if (context.Status is "active" or "overdue")
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                           Href="@($"/loans/return?loanId={context.LoanId}")">
                    Restituisci
                </MudButton>
            }
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[]{10, 20, 50, 100}" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<LoanDetail> _table = null!;
    private string _filter = "all";

    private async Task<TableData<LoanDetail>> LoadData(TableState state, CancellationToken ct)
    {
        var (items, total) = await LoanRepo.GetPagedAsync(state.Page, state.PageSize, _filter,
            state.SortLabel, state.SortDirection == SortDirection.Descending);
        return new TableData<LoanDetail> { Items = items, TotalItems = total };
    }

    private async Task SetFilter(string? f)
    {
        if (f is null) return;
        _filter = f;
        await _table.ReloadServerData();
    }

    private Color StatusColor(string status) => status switch
    {
        "active"   => Color.Info,
        "returned" => Color.Success,
        "overdue"  => Color.Error,
        _          => Color.Default
    };
}
