@page "/loans/borrow"
@inject LoanRepository LoanRepo
@inject BookRepository BookRepo
@inject CustomerRepository CustomerRepo
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Nuovo Prestito — Library</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Nuovo Prestito</MudText>

@if (_customers is null)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudCard Elevation="2" Style="max-width:600px">
        <MudCardContent>
            <MudStack Spacing="4">
                <MudSelect T="int?" @bind-Value="_customerId" Label="Cliente" Variant="Variant.Outlined" Required="true">
                    <MudSelectItem T="int?" Value="null">— Seleziona cliente —</MudSelectItem>
                    @foreach (var c in _customers.Where(c => c.Status == "active"))
                    {
                        <MudSelectItem T="int?" Value="@c.CustomerId">@c.FullName</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="int?" @bind-Value="_bookId" Label="Libro" Variant="Variant.Outlined" Required="true">
                    <MudSelectItem T="int?" Value="null">— Seleziona libro —</MudSelectItem>
                    @foreach (var b in _books.Where(b => b.AvailableCopies > 0))
                    {
                        <MudSelectItem T="int?" Value="@b.BookId">
                            @b.Title (@b.AvailableCopies copie disponibili)
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudNumericField T="int" @bind-Value="_loanDays" Label="Durata prestito (giorni)"
                                 Variant="Variant.Outlined" Min="1" Max="180" />
            </MudStack>
        </MudCardContent>
        <MudCardActions Class="pa-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync"
                       StartIcon="@Icons.Material.Filled.CheckCircle" Disabled="_loading">
                Conferma Prestito
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick="@(() => Nav.NavigateTo("/loans"))" Class="ml-2">
                Annulla
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    private IEnumerable<Customer>? _customers;
    private IEnumerable<Book> _books = [];
    private int? _customerId;
    private int? _bookId;
    private int _loanDays = 30;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        var (customers, books) = (CustomerRepo.GetAllAsync(), BookRepo.GetAllAsync());
        _customers = await customers;
        _books = await books;
    }

    private async Task SubmitAsync()
    {
        if (_customerId is null || _bookId is null)
        {
            Snackbar.Add("Seleziona un cliente e un libro.", Severity.Warning);
            return;
        }
        _loading = true;
        try
        {
            await LoanRepo.BorrowAsync(_customerId.Value, _bookId.Value, _loanDays);
            Snackbar.Add("Prestito registrato con successo.", Severity.Success);
            Nav.NavigateTo("/loans");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        finally { _loading = false; }
    }
}
