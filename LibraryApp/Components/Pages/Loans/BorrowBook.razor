@page "/loans/borrow"
@inject LoanRepository LoanRepo
@inject BookRepository BookRepo
@inject CustomerRepository CustomerRepo
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Nuovo Prestito — Library</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Nuovo Prestito</MudText>

@if (_customers is null)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudCard Elevation="2" Style="max-width:600px">
        <MudCardContent>
            <MudStack Spacing="4">
                <MudAutocomplete T="Customer" Label="Cliente" Variant="Variant.Outlined" Required="true"
                                 @bind-Value="_selectedCustomer"
                                 SearchFunc="SearchCustomers"
                                 ToStringFunc="@(c => c?.FullName ?? string.Empty)"
                                 MinCharacters="0" MaxItems="50" CoerceText="true" />

                <MudAutocomplete T="Book" Label="Libro" Variant="Variant.Outlined" Required="true"
                                 @bind-Value="_selectedBook"
                                 SearchFunc="SearchBooks"
                                 ToStringFunc="@(b => b == null ? string.Empty : $"{b.Title} ({b.AvailableCopies} copie disponibili)")"
                                 MinCharacters="0" MaxItems="50" CoerceText="true" />

                <MudNumericField T="int" @bind-Value="_loanDays" Label="Durata prestito (giorni)"
                                 Variant="Variant.Outlined" Min="1" Max="180" />
            </MudStack>
        </MudCardContent>
        <MudCardActions Class="pa-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync"
                       StartIcon="@Icons.Material.Filled.CheckCircle" Disabled="_loading">
                Conferma Prestito
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick="@(() => Nav.NavigateTo("/loans"))" Class="ml-2">
                Annulla
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    private IEnumerable<Customer>? _customers;
    private IEnumerable<Book> _books = [];
    private Customer? _selectedCustomer;
    private Book? _selectedBook;
    private int _loanDays = 30;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        var (customers, books) = (CustomerRepo.GetAllAsync(), BookRepo.GetAllAsync());
        _customers = await customers;
        _books = await books;
    }

    private Task<IEnumerable<Customer>> SearchCustomers(string value, CancellationToken _)
    {
        var active = _customers!.Where(c => c.Status == "active");
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(active);
        return Task.FromResult(active.Where(c => c.FullName.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private Task<IEnumerable<Book>> SearchBooks(string value, CancellationToken _)
    {
        var available = _books.Where(b => b.AvailableCopies > 0);
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(available);
        return Task.FromResult(available.Where(b => b.Title.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task SubmitAsync()
    {
        if (_selectedCustomer is null || _selectedBook is null)
        {
            Snackbar.Add("Seleziona un cliente e un libro.", Severity.Warning);
            return;
        }
        _loading = true;
        try
        {
            await LoanRepo.BorrowAsync(_selectedCustomer.CustomerId, _selectedBook.BookId, _loanDays);
            Snackbar.Add("Prestito registrato con successo.", Severity.Success);
            Nav.NavigateTo("/loans");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        finally { _loading = false; }
    }
}
