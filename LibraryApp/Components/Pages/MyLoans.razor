@page "/my-loans"
@attribute [Authorize(Roles = "user")]
@inject ILoanRepository LoanRepo
@inject AuthenticationStateProvider AuthState

<PageTitle>I Miei Prestiti — Library</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">I Miei Prestiti</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4 mud-text-secondary">Storico completo dei tuoi prestiti</MudText>

@if (_overdueCount > 0)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        Hai @_overdueCount prestito@(_overdueCount == 1 ? "" : "i") scaduto@(_overdueCount == 1 ? "" : "i").
    </MudAlert>
}

<MudToggleGroup T="string" Value="_filter" ValueChanged="SetFilter" Color="Color.Primary" Outlined="true" Class="mb-4">
    <MudToggleItem Value="@("all")">Tutti</MudToggleItem>
    <MudToggleItem Value="@("active")">Attivi</MudToggleItem>
    <MudToggleItem Value="@("overdue")">Scaduti</MudToggleItem>
    <MudToggleItem Value="@("returned")">Restituiti</MudToggleItem>
</MudToggleGroup>

<MudTable @ref="_table" T="LoanDetail" ServerData="LoadData" Hover="true" Dense="true" Striped="true" Elevation="2" RowsPerPage="20">
    <HeaderContent>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="book">Libro</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="loandate">Data Prestito</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="duedate">Scadenza</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="returndate">Restituzione</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="status">Stato</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LoanDetail" SortLabel="fine">Multa</MudTableSortLabel></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.BookTitle</MudTd>
        <MudTd>@context.LoanDate.ToString("dd/MM/yyyy")</MudTd>
        <MudTd>@context.DueDate.ToString("dd/MM/yyyy")</MudTd>
        <MudTd>@(context.ReturnDate?.ToString("dd/MM/yyyy") ?? "—")</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">
                @StatusLabel(context.Status)
            </MudChip>
        </MudTd>
        <MudTd>
            @if (context.FineAmount.HasValue)
            {
                <MudText Color="@(context.FinePaid ? Color.Default : Color.Error)">
                    € @context.FineAmount.Value.ToString("F2")
                    @(context.FinePaid ? " ✓" : "")
                </MudText>
            }
            else if (context.DaysOverdue > 0)
            {
                <MudText Color="Color.Warning">
                    ~€ @context.EstimatedFine.ToString("F2")
                </MudText>
            }
            else
            {
                <MudText>—</MudText>
            }
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[]{10, 20, 50}" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<LoanDetail> _table = null!;
    private int _userId;
    private string _filter = "all";
    private int _overdueCount;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var claim = state.User.FindFirst("user_id")?.Value;
        _userId = int.TryParse(claim, out var id) ? id : 0;

        if (_userId != 0)
        {
            var (_, total) = await LoanRepo.GetByUserIdPagedAsync(_userId, 0, 1, "overdue");
            _overdueCount = total;
        }
    }

    private async Task<TableData<LoanDetail>> LoadData(TableState state, CancellationToken ct)
    {
        if (_userId == 0)
            return new TableData<LoanDetail> { Items = [], TotalItems = 0 };

        var (items, total) = await LoanRepo.GetByUserIdPagedAsync(_userId, state.Page, state.PageSize,
            _filter, state.SortLabel, state.SortDirection == SortDirection.Descending);
        return new TableData<LoanDetail> { Items = items, TotalItems = total };
    }

    private async Task SetFilter(string? f)
    {
        if (f is null) return;
        _filter = f;
        await _table.ReloadServerData();
    }

    private static Color StatusColor(string status) => status switch
    {
        "active"   => Color.Info,
        "returned" => Color.Success,
        "overdue"  => Color.Error,
        _          => Color.Default
    };

    private static string StatusLabel(string status) => status switch
    {
        "active"   => "Attivo",
        "returned" => "Restituito",
        "overdue"  => "Scaduto",
        _          => status
    };
}
