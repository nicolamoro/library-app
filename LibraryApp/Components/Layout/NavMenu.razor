<AuthorizeView Roles="admin">
    <Authorized>
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/books" Icon="@Icons.Material.Filled.MenuBook">
                Libri
            </MudNavLink>
            <MudNavLink Href="/users" Icon="@Icons.Material.Filled.ManageAccounts">
                Utenti
            </MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/loans" Icon="@Icons.Material.Filled.FormatListBulleted">
                Prestiti
            </MudNavLink>
            <MudNavLink Href="/loans/borrow" Icon="@Icons.Material.Filled.AddCircleOutline">
                Nuovo Prestito
            </MudNavLink>
            <MudNavLink Href="/loans/return" Icon="@Icons.Material.Filled.AssignmentReturn">
                Restituzione
            </MudNavLink>
        </MudNavMenu>
    </Authorized>
</AuthorizeView>

<AuthorizeView Roles="user">
    <Authorized>
        <MudNavMenu>
            <MudNavLink Href="/my-loans" Icon="@Icons.Material.Filled.FormatListBulleted">
                I Miei Prestiti
            </MudNavLink>
        </MudNavMenu>
    </Authorized>
</AuthorizeView>
